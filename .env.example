# Fast File Transfer — server configuration.
# Copy this file to `.env` and fill in your own values. NEVER commit the real .env.

# --- Auth -------------------------------------------------------------------
# Shared secret that clients must present (Authorization: Bearer <token>).
# Generate a long random value, e.g.  openssl rand -hex 32
# An empty value disables auth (DEV ONLY — never run a public server without a token).
FFT_TOKEN=replace-with-a-long-random-secret

# --- Network ----------------------------------------------------------------
# Address/port the server listens on.
FFT_HOST=0.0.0.0
FFT_PORT=8787

# --- Storage ----------------------------------------------------------------
# Directory for completed files and in-progress chunk sessions.
FFT_STORAGE_DIR=./fft-data

# --- Limits -----------------------------------------------------------------
# Max bytes per file. Init is rejected (413) above this. Default 20 GiB.
FFT_MAX_FILE_BYTES=21474836480

# Upload chunk size in bytes (client default). 8 MiB.
FFT_CHUNK_BYTES=8388608

# Optional total storage quota per auth-token, in bytes. -1 = unlimited.
FFT_QUOTA_BYTES=-1

# Keep a completed file this many days before auto-expiry. 0 = keep forever.
FFT_RETENTION_DAYS=30

# Refuse an upload that would leave less than this much free disk (bytes). 512 MiB.
FFT_DISK_MARGIN_BYTES=536870912

# Abandon an in-progress upload session idle for this many minutes (frees reservation).
FFT_SESSION_IDLE_MINUTES=60
